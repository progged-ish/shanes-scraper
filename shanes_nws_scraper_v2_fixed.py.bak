def parse_zulu_timestamp(zulu_str):
    """Parse NWS Zulu timestamp from header like 'FXUS66 KMTR 311029'."""
    try:
        day, hour, minute = int(zulu_str[0:2]), int(zulu_str[2:4]), int(zulu_str[4:6])
        now_utc = datetime.now(timezone.utc)
        target_date = now_utc - relativedelta(months=1) if day > now_utc.day else now_utc
        return target_date.replace(day=day, hour=hour, minute=minute, second=0, microsecond=0)
    except (ValueError, IndexError):
        return None

def fetch_afd(wfo):
    """
    Fetch Area Forecast Discussion using HTML scraping.
    Uses BeautifulSoup to parse the <pre> tag from the NWS product page.
    
    Args:
        wfo: Weather Forecast Office identifier (e.g., 'ANC', 'DFW')
    
    Returns:
        Tuple of (discussion_text, discussion_url, timestamp_obj)
    """
    url = f"https://forecast.weather.gov/product.php?site={wfo.upper()}&issuedby={wfo.upper()}&product=AFD&format=txt&version=1&glossary=0"
    
    try:
        # Note: No custom headers - use default requests User-Agent
        # Use 15s timeout as per original working script
        response = requests.get(url, timeout=15)
        
        # Handle 400/404 errors
        if response.status_code == 400 or response.status_code == 404:
            return f"Error {response.status_code} for {wfo.upper()}", url, None
        
        response.raise_for_status()
        
        # Parse HTML with BeautifulSoup
        soup = BeautifulSoup(response.text, 'html.parser')
        pre = soup.find('pre')
        
        if pre:
            text = pre.get_text()
            # Extract Zulu timestamp from header
            zulu_match = re.search(r'^[A-Z]{4}\d{2}\s+K[A-Z]{3}\s+(\d{6})', text, re.MULTILINE)
            timestamp_obj = parse_zulu_timestamp(zulu_match.group(1)) if zulu_match else None
            return text, url, timestamp_obj
        else:
            return f"Could not find discussion text for {wfo.upper()}", url, None
            
    except requests.exceptions.RequestException as e:
        return f"Error fetching {wfo.upper()}: {str(e)}", url, None


def get_ai_summary(text: str) -> str:
    """
    Generate AI-powered summary using Hermes.
    
    Args:
        text: Forecast discussion text
        
    Returns:
        AI-generated summary string
    """
    if not summarizer:
        return "[AI Summary unavailable - API key not configured]"
    
    try:
        summary = summarizer.generate_summary(text)
        return summary
    except Exception as e:
        return f"[AI Summary error: {str(e)[:100]}]"


def highlight_keywords(text: str, color_map: dict) -> str:
    """Apply colored span tags to keywords in text."""
    highlighted = html.escape(text)
    sorted_kws = sorted(color_map.keys(), key=len, reverse=True)
    
    for kw in sorted_kws:
        color = color_map.get(kw, '#E0E0E0')
        pattern = r'(\b' + re.escape(kw) + r'\b)'
        highlighted = re.sub(
            pattern,
            lambda m: f'<span style="background-color:{color}; font-weight:bold; padding: 2px 0; border-radius: 3px;">{m.group(1)}</span>',
            highlighted,
            flags=re.IGNORECASE
        )
    
    return highlighted


def create_folium_map(office_coords: dict) -> str:
    """Create Folium map with office locations."""
    center = [45, -98.5795]
    m = folium.Map(location=center, zoom_start=4, tiles='CartoDB positron')
    
    for office, coords in office_coords.items():
        popup_html = f"""<b>{office}</b><br>
                       <a href="#" onclick="openDiscussion('{office}')">Open AFD</a>"""
        folium.CircleMarker(
            location=coords, radius=5,
            popup=folium.Popup(popup_html, max_width=200),
            color='#007bff', fill_color='#007bff',
            fill=True, fill_opacity=0.7
        ).add_to(m)
    
    # Add CSS for full-screen map
    m.get_root().html.add_child(folium.Element('<style>html, body, #map { height: 100%; margin: 0; padding: 0; width: 100%; } #map { position: absolute; top: 0; left: 0; right: 0; bottom: 0; }</style>'))
    
    return m._repr_html_()


