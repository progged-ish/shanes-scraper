def generate_keyword_summary(keyword_map: dict, keyword_counts: dict, keyword_occurrences: dict = None) -> str:
    """Generate keyword summary section with clickable links to text occurrences."""
    html_parts = []
    
    for kw in sorted(keyword_counts.keys()):
        count = keyword_counts[kw]
        color = KEYWORD_COLORS.get(kw.lower(), '#E0E0E0')
        display_kw = ' '.join(word.capitalize() for word in kw.split())
        
        html_parts.append(f"""
            <details>
                <summary><span style="background-color:{color}; padding: 3px 8px; border-radius: 3px; font-weight: bold;">{display_kw}</span> ({count} occurrences)</summary>
                <ul>
        """)
        
        # If we have specific occurrences data, use it
        if keyword_occurrences and kw.lower() in keyword_occurrences:
            for occ in keyword_occurrences[kw.lower()]:
                office = occ.get('office', '')
                state = occ.get('state', '')
                text = occ.get('text', '')
                if office:
                    html_parts.append(f'            <li><a href="#{office.upper()}"><strong>{get_state_abbrev(state)} - {office.upper()}</strong></a><br><small>"{text[:50]}..."</small></li>')
        else:
            # Fallback: show office locations
            for state in sorted(keyword_map.get(kw.lower(), {}).keys()):
                for office in sorted(keyword_map[kw.lower()][state]):
                    html_parts.append(f'            <li><a href="#{office.upper()}">{get_state_abbrev(state)} - {office.upper()}</a></li>')
        
        html_parts.append("""
                </ul>
            </details>
        """)
    
    return '\n'.join(html_parts)


def generate_office_summaries(summaries: dict) -> str:
    """Generate office-by-office summaries section."""
    html_parts = []
    
    for state in sorted(summaries.keys()):
        state_id = get_state_abbrev(state).replace(' ', '_')
        
        html_parts.append(f"""
            <h2 id="{state_id}">--- {state.upper()} ---</h2>
        """)
        
        for office in sorted(summaries[state].keys()):
            data = summaries[state][office]
            office_id = office.upper()
            
            html_parts.append(f"""
                <hr>
                <h3 id="{office_id}">NWS Office: {office.upper()}</h3>
                <h4>🤖 AI-BULLETIN:</h4>
                <div class="ai-summary">
                    {html.escape(data['ai_summary'])}
                </div>
                <h4>🔑 Keyword Features:</h4>
            """)
            
            if data['keyword_summary']:
                html_parts.append('<ul>')
                for item in data['keyword_summary']:
                    html_parts.append(f'                <li>{highlight_keywords(item, KEYWORD_COLORS)}</li>')
                html_parts.append('</ul>')
            else:
                html_parts.append('<p><em>No significant keywords detected</em></p>')
            
            html_parts.append(f"""
                <details>
                    <summary><strong>Full Discussion Text</strong></summary>
                    <pre>{html.escape(data['full_text'])}</pre>
                </details>
                <p><strong>Full AFD:</strong> <a href="{data['url']}" target="_blank">{data['url']}</a></p>
                <a href="#top" class="back-to-top">Back to Top</a>
            """)
    
    return '\n'.join(html_parts)




