def main():
    """Main execution function."""
    print("=" * 60)
    print("Shane's NWS Discussion Scraper v2.0 - AI Enhanced")
    print("=" * 60)
    
    execution_time = datetime.now(timezone.utc).strftime("%Y-%m-%d %H:%M:%S UTC")
    version = "2.0.0 (AI-Powered)"
    
    print(f"\n🤖 AI Summary Module: {'ENABLED' if summarizer else 'DISABLED (no API key)'}")
    print(f"⏰ Execution time: {execution_time}\n")
    
    # Process all offices
    processed_data = {
        'summaries': {},
        'keyword_map': defaultdict(list),
        'keyword_counts': defaultdict(int),
        'keyword_occurrences': defaultdict(list),
        'map_html': '',
        'base_url': ''
    }
    
    # Fetch map
    offices_to_plot = {o: c for o, c in nws_office_coords.items() 
                      if any(o in offices for offices in all_offices_synoptic.values())}
    processed_data['map_html'] = create_folium_map(offices_to_plot)
    processed_data['base_url'] = 'https://forecast.weather.gov/product.php?site='
    
    print(f"\n📡 Fetching {len(offices_to_plot)} forecast discussions...")
    print("-" * 60)
    
    # Process each office
    for state, offices in all_offices_synoptic.items():
        state_abbrev = get_state_abbrev(state)
        for i, office in enumerate(offices):
            print(f"  [{office}] ", end="", flush=True)
            
            try:
                # Small delay between requests to avoid rate limiting
                import time
                if i > 0:
                    time.sleep(0.5)
                
                # Fetch discussion
                # Fetch discussion with 12-second delay between requests (to respect NWS rate limits)
                discussion, url, timestamp = fetch_afd(office)
                
                # Log timestamp if available
                if timestamp:
                    print(f"   ✓ {office}: {timestamp.strftime('%Y-%m-%d %H:%M UTC')}")
                else:
                    print(f"   ✓ {office}: fetched")
                
                # Extract keywords
                keyword_summary, keyword_counts = [], defaultdict(int)
                
                # Respect NWS rate limits - sleep 12 seconds between requests
                time.sleep(12)
                sentences = re.split(r'(?<=[.!?])\s+', discussion.replace('\n', ' '))
                
                for sentence in sentences:
                    matching_kws = [k for k in KEYWORDS 
                                   if re.search(r'\b' + re.escape(k) + r'\b', sentence, re.IGNORECASE)]
                    if matching_kws:
                        clean_sent = sentence.strip()
                        if clean_sent not in keyword_summary:
                            keyword_summary.append(clean_sent)
                        for kw in matching_kws:
                            keyword_counts[kw.lower()] += 1
                            # Track occurrence with office info
                            processed_data['keyword_occurrences'][kw.lower()].append({
                                'office': office,
                                'state': state_abbrev,
                                'text': clean_sent
                            })
                
                # Generate AI summary
                ai_summary = get_ai_summary(discussion)
                
                processed_data['summaries'][state_abbrev][office] = {
                    'full_text': discussion,
                    'url': url,
                    'keyword_summary': keyword_summary,
                    'keyword_counts': dict(keyword_counts),
                    'ai_summary': ai_summary
                }

                # Update global keyword counts
                for kw, count in keyword_counts.items():
                    processed_data['keyword_counts'][kw] += count
                    processed_data['keyword_map'][kw][state_abbrev].append(office)
                
                print("✓")
                
            except Exception as e:
                print(f"✗ Error ({state_abbrev}): {e}")
    
    # Generate dashboard
    print("\n" + "=" * 60)
    print("📊 Generating Dashboard...")
    
    dashboard_html = generate_dashboard_html(
        processed_data,
        execution_time,
        version
    )
    
    # Save output files
    # Save as HTML file
    html_output_path = os.path.join(DATA_DIR, "shanes_nws_dashboard_v2.html")
    with open(html_output_path, 'w', encoding='utf-8') as f:
        f.write(dashboard_html)
    
    # Also save as .txt file for compatibility
    output_path = os.path.join(DATA_DIR, "shanes_nws_dashboard_v2.txt")
    with open(output_path, 'w', encoding='utf-8') as f:
        f.write(dashboard_html)
    
    print(f"\n✓ Dashboard saved to:")
    print(f"   HTML: {html_output_path}")
    print(f"   TXT:  {output_path}")
    print(f"📁 File size: {os.path.getsize(html_output_path) / 1024:.1f} KB")
    
    # Open in browser if on local machine
    if os.name != 'nt':
        print("\n🌐 Opening dashboard in browser...")
        import webbrowser
        webbrowser.open('file://' + output_path)
    
    print("\n" + "=" * 60)
    print(f"✓ Processing complete! {len(offices_to_plot)} offices processed.")
    print("=" * 60)
    
    return dashboard_html


if __name__ == '__main__':
    main()
